def spread_fire (adj : Array UInt64) (burned : UInt64) : UInt64 := (List.range 64).foldl (init := burned) (fun acc i => if (burned >>> i.toUInt64) &&& 1 == 1 then acc ||| (adj[i]!) else acc)
