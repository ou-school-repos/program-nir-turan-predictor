  16 -- 48;
  17 -- 18;
  17 -- 49;
  18 -- 19;
  18 -- 50;
  19 -- 20;
  19 -- 51;
  20 -- 21;
  20 -- 52;
  21 -- 22;
  21 -- 53;
  22 -- 23;
  22 -- 54;
  23 -- 24;
  23 -- 55;
  24 -- 25;
  24 -- 56;
  25 -- 26;
  25 -- 57;
  26 -- 27;
  26 -- 58;
  27 -- 28;
