graph Spectrum {
  node [fontname="Helvetica", style=filled, fillcolor=white];
  1 [fillcolor=cyan, label="Hub 1"]; 3 [fillcolor=cyan, label="Hub 3"];
  0 -- 1;
  1 -- 2;
  1 -- 5;
  1 -- 6;
  1 -- 7;
  1 -- 8;
  1 -- 9;
  1 -- 10;
  1 -- 11;
  1 -- 12;
  2 -- 3;
  3 -- 4;
  3 -- 13;
  3 -- 14;
  3 -- 15;
  3 -- 16;
  3 -- 17;
  3 -- 18;
  3 -- 19;
  3 -- 20;
}
