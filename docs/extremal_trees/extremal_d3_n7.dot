graph T7 {
  label="N=7, i(T)=41, leaves=4, diam=4";
  labelloc=t;
  fontname="Inter";
  fontsize=14;
  node [shape=circle, style=filled, width=0.35, fontsize=10, fontname="Inter"];
  edge [color="#555555"];

  0 [fillcolor="#a8e6cf", label="0"];
  1 [fillcolor="#ffd3b6", label="1"];
  2 [fillcolor="#dcedc1", label="2"];
  3 [fillcolor="#ffd3b6", label="3"];
  4 [fillcolor="#a8e6cf", label="4"];
  5 [fillcolor="#a8e6cf", label="5"];
  6 [fillcolor="#a8e6cf", label="6"];

  0 -- 1;
  1 -- 2;
  2 -- 3;
  3 -- 4;
  3 -- 5;
  1 -- 6;
}
